# Baby Pulmo — environment variables
# Copy to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Anthropic (Claude reasoning agent)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY

# Twilio (WhatsApp Business sandbox)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=YOUR_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Twilio sandbox default

# ElevenLabs (Bangla TTS)
ELEVENLABS_API_KEY=YOUR_KEY
ELEVENLABS_BANGLA_VOICE_ID=YOUR_VOICE_ID  # use any multilingual voice

# Classifier inference endpoint (Modal or Replicate URL)
CLASSIFIER_ENDPOINT=https://YOUR-USERNAME--babypulmo-classify.modal.run
CLASSIFIER_API_KEY=YOUR_KEY

# OpenAI (only used for text-embedding-3-large during IMCI ingest)
OPENAI_API_KEY=sk-YOUR_KEY
