# Baby Pulmo — environment variables
# Copy to .env.local and fill in your values

# ─── Supabase (DB + Storage + pgvector + PostGIS) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── Meta WhatsApp Cloud API (direct, no Twilio markup) ─────────────────
# Names match what lib/whatsapp.ts reads via process.env.* — do NOT prefix
# these with META_; the code expects bare WHATSAPP_* identifiers.
WHATSAPP_APP_SECRET=YOUR_APP_SECRET                  # for HMAC webhook verification
WHATSAPP_VERIFY_TOKEN=YOUR_VERIFY_TOKEN              # used during webhook handshake
WHATSAPP_ACCESS_TOKEN=YOUR_GRAPH_API_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_GRAPH_VERSION=v21.0                         # Meta Graph API version; lib/whatsapp.ts defaults to this

# ─── Google Cloud Text-to-Speech (Bangla TTS, bn-IN WaveNet) ────────────
GCP_TTS_API_KEY=YOUR_KEY
GCP_TTS_VOICE=bn-IN-Wavenet-A
TTS_CACHE_BUCKET=recordings

# ─── Classifier inference (Modal endpoint serving int8 ONNX) ────────────
CLASSIFIER_ENDPOINT=https://YOUR-USERNAME--babypulmo-classify.modal.run
CLASSIFIER_API_KEY=YOUR_KEY

# ─── OpenAI (only for text-embedding-3-large during IMCI ingest) ────────
OPENAI_API_KEY=sk-YOUR_KEY

# ─── Anthropic (only used for IMCI chunking during ingest, not runtime) ─
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY

# ─── Clinical content (private, loaded from BabyPulmo/clinical-content) ─
# These are JSON strings (no newlines). Generate with:
#   STOCK_BANGLA_JSON=$(jq -c . path/to/stock-bangla.json)
#   SEVERITY_RULES_JSON=$(jq -c . path/to/severity-rules.json)
# Without these, decideSeverity falls back to safe escalate-by-default; no
# runtime LLM generation ever takes over (Bangla stays clinician-vetted).
STOCK_BANGLA_JSON={}
SEVERITY_RULES_JSON={}

# ─── Phase 3 — Chest X-ray vision (TorchXrayVision DenseNet121 on Modal) ─
# CXR override is the highest-precedence rule in decideSeverityMultiModal:
# pneumonia ≥ 0.6 OR consolidation ≥ 0.6 → CRITICAL escalation.
# See babypulmo/lib/cxr-vision.ts + babypulmo/docs/CXR_README.md.
CXR_ENDPOINT=https://YOUR-USERNAME--babypulmo-cxr-vision-classify-endpoint.modal.run
CXR_API_KEY=YOUR_KEY

# ─── Phase 3 — Whisper Bangla onboarding ASR (large-v3 on Modal T4) ──────
# Used ONLY for caregiver onboarding voice replies ("say child age in years").
# Never used for caregiver-facing decisions or scripts — see ARCHITECTURE.md §3.
WHISPER_ENDPOINT=https://YOUR-USERNAME--babypulmo-whisper-transcribe-endpoint.modal.run
WHISPER_API_KEY=YOUR_KEY

# ─── Phase 2 — Cohere multilingual reranker (Hybrid Search path) ─────────
# Optional. When unset, lib/rag.ts::retrieveImciHybrid falls back to a
# blended (vec * 0.6 + ts * 0.4) score — still scores Hybrid Search,
# just without the multilingual reranker boost on Bangla protocol text.
COHERE_API_KEY=YOUR_KEY

# ─── Phase 1 — Lakehouse Parquet bucket (Supabase Storage) ───────────────
# scripts/export-audit-parquet.ts writes nightly partitions here; the
# /docs Audit Analytics cell reads via DuckDB-WASM. Defaults to "lakehouse"
# when unset.
AUDIT_PARQUET_BUCKET=lakehouse

# ─── Phase 2 — MCP servers (mcp/{classifier,imci-rag,chw-routing}-server) ─
# The MCP servers run outside Next.js (stdio transport) so they expect
# SUPABASE_URL not NEXT_PUBLIC_SUPABASE_URL. Mirror the public URL here.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
