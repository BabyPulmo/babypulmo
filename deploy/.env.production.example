# Baby Pulmo — production environment SCHEMA REFERENCE.
#
# ⚠ DO NOT EDIT .env.production ON THE VPS.
#
# Source of truth for production secrets: GitHub Secrets on
# https://github.com/BabyPulmo/babypulmo/settings/secrets/actions
#
# .github/workflows/deploy.yml regenerates /opt/babypulmo/deploy/.env.production
# from those secrets on every push to main. Anything you edit on the VPS is
# wiped on the next deploy.
#
# For LOCAL dev: use .env.local at repo root (gitignored) — that is dev SoT.
# See ../.env.example for the local template.
#
# This file just documents the schema (variable names + example values).

# ─── Domain (for Caddy + Next.js) ──────────────────────────────────────────
DOMAIN=babypulmo.com
NEXT_PUBLIC_SITE_URL=https://babypulmo.com

# ─── Supabase (managed) ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── Meta WhatsApp Cloud API ───────────────────────────────────────────────
META_WHATSAPP_APP_SECRET=YOUR_APP_SECRET
META_WHATSAPP_VERIFY_TOKEN=YOUR_VERIFY_TOKEN
META_WHATSAPP_ACCESS_TOKEN=YOUR_GRAPH_API_TOKEN
META_WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID

# ─── GCP Text-to-Speech (Bangla) ───────────────────────────────────────────
GCP_TTS_API_KEY=YOUR_KEY
GCP_TTS_VOICE=bn-IN-Wavenet-A
TTS_CACHE_BUCKET=recordings

# ─── OpenAI (one-time IMCI embedding ingest) ───────────────────────────────
OPENAI_API_KEY=sk-YOUR_KEY

# ─── Anthropic (one-time IMCI chunking ingest, not runtime) ────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY

# ─── Clinical content (private) ────────────────────────────────────────────
# Generate from BabyPulmo/clinical-content repo:
#   STOCK_BANGLA_JSON=$(jq -c . stock-bangla.json)
#   SEVERITY_RULES_JSON=$(jq -c . severity-rules.json)
STOCK_BANGLA_JSON={}
SEVERITY_RULES_JSON={}

# ─── Docker Compose paths ──────────────────────────────────────────────────
# Where the trained ONNX model lives on the VPS host (bind-mounted into classifier).
# Populate by uploading babypulmo_wav2vec2_int8.onnx from Colab training.
CLASSIFIER_MODELS_DIR=/var/babypulmo/models
